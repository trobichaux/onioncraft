{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/_next/*", "/*.{css,js,png,gif,jpg,jpeg,svg,ico,webp,woff,woff2}"]
  },
  "routes": [
    {
      "route": "/api/v1/*",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH"]
    }
  ],
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  }
}
